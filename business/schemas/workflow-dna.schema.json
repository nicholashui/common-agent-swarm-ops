{
  "$id": "workflow-dna.schema.json",
  "title": "Bounded WorkflowDNA and Pack Graph",
  "oneOf": [
    {"$ref": "#/$defs/workflowDna"},
    {"$ref": "#/$defs/packGraph"}
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]{0,99}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_node_visits", "max_handoffs", "max_wall_clock_seconds", "max_tool_requests"],
      "properties": {
        "max_node_visits": {"type": "integer", "minimum": 1, "maximum": 100},
        "max_handoffs": {"type": "integer", "minimum": 0, "maximum": 12},
        "max_wall_clock_seconds": {"type": "integer", "minimum": 1, "maximum": 900},
        "max_tool_requests": {"type": "integer", "minimum": 0, "maximum": 50}
      }
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reads", "writes"],
      "properties": {
        "reads": {"$ref": "#/$defs/identifierList"},
        "writes": {"$ref": "#/$defs/identifierList"}
      }
    },
    "identifierList": {
      "type": "array",
      "items": {"$ref": "#/$defs/identifier"},
      "uniqueItems": true
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan_id", "compensation_step_ids"],
      "properties": {
        "plan_id": {"$ref": "#/$defs/identifier"},
        "compensation_step_ids": {"$ref": "#/$defs/identifierList"}
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "agent_id", "tool_ids", "memory_reads", "memory_writes"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "agent_id": {"$ref": "#/$defs/identifier"},
        "tool_ids": {"$ref": "#/$defs/identifierList"},
        "memory_reads": {"$ref": "#/$defs/identifierList"},
        "memory_writes": {"$ref": "#/$defs/identifierList"}
      }
    }
,
    "workflowDna": {
      "type": "object",
      "additionalProperties": false,
      "required": ["definition_type", "id", "version", "owner_id", "authorization_id", "engine", "execution_budget", "memory", "risk_gate_ids", "rollback", "steps"],
      "properties": {
        "definition_type": {"const": "workflow_dna"},
        "id": {"$ref": "#/$defs/identifier"},
        "version": {"$ref": "#/$defs/version"},
        "owner_id": {"$ref": "#/$defs/identifier"},
        "authorization_id": {"$ref": "#/$defs/identifier"},
        "engine": {"enum": ["legacy", "graph"]},
        "execution_budget": {"$ref": "#/$defs/budget"},
        "memory": {"$ref": "#/$defs/memory"},
        "risk_gate_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "rollback": {"$ref": "#/$defs/rollback"},
        "steps": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"$ref": "#/$defs/step"}, "uniqueItems": true}
      }
    },
    "graphNode": {"$ref": "#/$defs/step"},
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "max_traversals"],
      "properties": {
        "from": {"$ref": "#/$defs/identifier"},
        "to": {"$ref": "#/$defs/identifier"},
        "max_traversals": {"type": "integer", "minimum": 1, "maximum": 10}
      }
    },
    "packGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["definition_type", "id", "version", "owner_id", "authorization_id", "engine", "execution_budget", "memory", "risk_gate_ids", "rollback", "pattern", "nodes", "edges", "entry_node", "terminal_node_ids"],
      "properties": {
        "definition_type": {"const": "pack_graph"},
        "id": {"$ref": "#/$defs/identifier"},
        "version": {"$ref": "#/$defs/version"},
        "owner_id": {"$ref": "#/$defs/identifier"},
        "authorization_id": {"$ref": "#/$defs/identifier"},
        "engine": {"const": "graph"},
        "execution_budget": {"$ref": "#/$defs/budget"},
        "memory": {"$ref": "#/$defs/memory"},
        "risk_gate_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "rollback": {"$ref": "#/$defs/rollback"},
        "pattern": {"enum": ["pipeline", "supervisor", "router", "critique", "map_reduce", "pack_spine"]},
        "nodes": {"type": "array", "minItems": 1, "maxItems": 100, "items": {"$ref": "#/$defs/graphNode"}, "uniqueItems": true},
        "edges": {"type": "array", "items": {"$ref": "#/$defs/edge"}, "uniqueItems": true},
        "entry_node": {"$ref": "#/$defs/identifier"},
        "terminal_node_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true}
      }
    }
  }
}
