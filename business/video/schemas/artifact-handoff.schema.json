  "type": "object",
  "required": ["artifact_id", "version", "parent_assets", "brief_scope", "technical_spec", "rights_and_consent", "continuity_state", "qc_status", "target_channels", "provenance_manifest"],
  "properties": {
    "artifact_id": {"type": "string", "minLength": 1},
