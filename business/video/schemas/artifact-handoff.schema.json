    "qc_status": {"type": "object", "required": ["l1", "l2", "l3", "q1", "q2", "q3", "q4", "q5", "q6"]},
    "target_channels": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "provenance_manifest": {"type": "object", "required": ["provenance_reference", "critique_log_reference", "final_signoff_chain", "model_prompt_inputs"], "properties": {"provenance_reference": {"type": "string", "minLength": 1}, "critique_log_reference": {"type": "string", "minLength": 1}, "final_signoff_chain": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "model_prompt_inputs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}}}
  },
  "additionalProperties": false
}
