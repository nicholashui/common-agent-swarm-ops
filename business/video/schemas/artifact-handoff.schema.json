    "rights_and_consent": {"type": "object", "required": ["license", "likeness_consent", "voice_consent", "territories", "embargo_state"], "properties": {"license": {"type": "string", "minLength": 1}, "likeness_consent": {"type": "string", "minLength": 1}, "voice_consent": {"type": "string", "minLength": 1}, "territories": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "embargo_state": {"type": "string", "minLength": 1}}},
